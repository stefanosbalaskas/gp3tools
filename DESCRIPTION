Package: gp3tools
Type: Package
Title: Import, Inspect, Analyse, and Report Gazepoint GP3 Exports
Version: 2.0.1
Authors@R: c(
    person(
      given = "Stefanos",
      family = "Balaskas",
      email = "s.balaskas@ac.upatras.gr",
      role = c("aut", "cre"),
      comment = c(ORCID = "0000-0003-2444-9796")
    )
